[Unit]
Description=Armosphera One Claude (Fastify + web-modern SPA + legacy escape hatch)
After=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__ROOT__
ExecStart=__NODE__ __ROOT__/deploy/scripts/start-all.sh
Restart=always
RestartSec=5
Environment=DEPLOY_DEFAULT=__DEPLOY_DEFAULT__
Environment=SPA_PORT=__SPA_PORT__
Environment=BACKEND_PORT=__PORT__
Environment=HOST=127.0.0.1
Environment=NODE_ENV=production
StandardOutput=append:__ROOT__/logs/systemd.out.log
StandardError=append:__ROOT__/logs/systemd.err.log

[Install]
WantedBy=multi-user.target
