# Fastify backend — same as the legacy Vite app's vite.config.js proxy.
# In dev the new app's server route at /api/$ reverse-proxies to this URL.
FASTIFY_BACKEND_URL=http://localhost:4100

# Local LLM for lightweight agents (matches the paperclip local-llm strategy).
# :11434 is blocked on this host (ollama app wedged) — use :11435 (CLI).
OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_MODEL=qwen2.5:7b

# Vercel AI SDK provider for cloud-based agents.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
