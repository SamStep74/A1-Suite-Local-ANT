{
  "name": "armosphera-one-claude",
  "version": "0.1.0",
  "private": true,
  "description": "A1 Suite — sovereign, self-hostable Armenian business operating system with Zoho One functional parity. Local-first, offline-capable, opt-in AI.",
  "type": "commonjs",
  "main": "server/index.js",
  "//comment-scripts": "10.1 deployment flip: build:ui = web-modern SPA (default); start:spa = SPA server on PORT; start:all = both via concurrently",
  "scripts": {
    "start": "node server/index.js",
    "start:lan": "HOST=0.0.0.0 node server/index.js",
    "start:spa": "node web-modern/scripts/serve-spa.mjs",
    "start:all": "concurrently --kill-others-on-fail --names backend,spa --prefix-colors auto 'node server/index.js' 'node web-modern/scripts/serve-spa.mjs'",
    "dev": "NODE_ENV=development node --watch server/index.js",
    "dev:lan": "HOST=0.0.0.0 NODE_ENV=development node --watch server/index.js",
    "build:ui": "npm --prefix web-modern install && npm --prefix web-modern run build",
    "test": "node --test --test-concurrency=4 --test-timeout=180000",
    "karpathy:list": "node scripts/karpathy-eval.mjs --list",
    "karpathy:program": "node scripts/karpathy-eval.mjs --program",
    "karpathy:run": "node scripts/karpathy-eval.mjs --run",
    "smoke": "node scripts/smoke.js",
    "install:server": "bash deploy/install.sh",
    "health": "bash deploy/scripts/healthcheck.sh",
    "backup": "bash deploy/backup.sh"
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@a1/ai": "git+https://github.com/Armosphera/A1-AI-Core.git#cec47006254640e7c02aea07b375ea5d0d471cb8",
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.3"
  }
}
